COMPOSE_PROJECT_NAME=oj-training-data-manager

# This volume name is deliberately unrelated to any other project.
TRAINING_DB_VOLUME_NAME=oj-training-data-manager_training-db-data
TRAINING_LOG_VOLUME_NAME=oj-training-data-manager_training-api-logs
TRAINING_DB_NAME=oj_training_data
TRAINING_DB_USERNAME=oj_training
TRAINING_DB_PASSWORD=change-me-training-db-password
TRAINING_DB_ROOT_PASSWORD=change-me-training-root-password

# Both preview ports bind to loopback by default. Set FRONTEND_BIND_ADDRESS=0.0.0.0
# only behind a trusted network boundary and HTTPS termination.
BACKEND_PORT=8190
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3100

# Required for every POST, PUT, PATCH and DELETE request.
# Use a long random value in a real deployment and transport it only over HTTPS.
TRAINING_OPERATION_PASSWORD=change-me-operation-password

# Automatic collection is intentionally disabled by default.
TRAINING_JOB_ITEM_INTERVAL=4s
TRAINING_DAILY_COLLECTION_LOOKBACK=100h
TRAINING_INTRADAY_COLLECTION_LOOKBACK=0h
TRAINING_CODEFORCES_DAILY_COLLECTION_ENABLED=false
TRAINING_CODEFORCES_INTRADAY_COLLECTION_ENABLED=false
TRAINING_ATCODER_DAILY_COLLECTION_ENABLED=false
TRAINING_ATCODER_INTRADAY_COLLECTION_ENABLED=false
TRAINING_ATCODER_PROBLEM_LIST_SCHEDULE_ENABLED=false
TRAINING_ATCODER_PROBLEM_LIST_BOOTSTRAP_ENABLED=false
